# Copy this file to .env and fill in real values. Never commit .env

GROQ_API_KEY=gsk_your-groq-key-here
NVIDIA_API_KEY=nvapi-your-nvidia-key-here
TOGETHER_API_KEY=your-together-ai-key-here

# Which LLM to use: "groq", "nvidia", or "together"
LLM_PROVIDER=groq

# SQLite for local dev (default) — override with Neon URL in production
DATABASE_URL=sqlite:///./afe.db

# Neon PostgreSQL connection string (set this to enable real DB user lookups)
NEON_DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# App
APP_ENV=development
APP_PORT=8000
