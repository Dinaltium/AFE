# Copy this file to .env and fill in real values. Never commit .env

# LLM Providers (use one or all three for fallback)
GROQ_API_KEY=gsk_your-groq-key-here
NVIDIA_API_KEY=nvapi-your-nvidia-nim-key-here
TOGETHER_API_KEY=your-together-ai-key-here

# Primary provider: groq | nvidia | together
LLM_PROVIDER=groq

# Database
DATABASE_URL=sqlite:///./afe.db
NEON_DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# App
APP_ENV=development
APP_PORT=8000
